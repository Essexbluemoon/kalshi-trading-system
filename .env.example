# ──────────────────────────────────────────────────────────────────────────────
# Kalshi Trading System — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Kalshi API credentials (get from https://kalshi.com/account/api-keys)
KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_api_secret_here
KALSHI_ENV=prod          # prod | demo  (use "demo" for sandbox testing)

# PostgreSQL connection string
# Local dev (docker-compose):    postgresql://postgres:postgres@db:5432/kalshi_trading
# Railway:                        filled in automatically by Railway plugin
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kalshi_trading

# Ingestion service
POLL_INTERVAL_SECONDS=300   # how often to poll Kalshi API (default 5 min)

# Backend API
API_KEY=change_me_before_deploy    # Bearer token for dashboard auth
CORS_ORIGINS=http://localhost:3000 # comma-separated list of allowed origins

# Alerts (optional — leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ALERT_PHONE_FROM=
ALERT_PHONE_TO=

SENDGRID_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
