FROM python:3.12-slim
WORKDIR /app
COPY ingestion/requirements.txt ./ingestion/requirements.txt
RUN pip install --no-cache-dir -r ingestion/requirements.txt
COPY api/        ./api/
COPY ingestion/  ./ingestion/
COPY scripts/    ./scripts/
COPY benchmarks/ ./benchmarks/
ENV PYTHONPATH=/app/api:/app/ingestion
CMD ["sh", "-c", "python /app/scripts/migrate.py && exec python /app/ingestion/run.py"]
