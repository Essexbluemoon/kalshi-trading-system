# Copy to .env.local for local development.
# The Vite proxy rewrites /api/* → http://localhost:8000/*,
# so set VITE_API_URL=/api in dev and the full backend URL in production.

# Local dev (uses Vite proxy)
VITE_API_URL=/api
VITE_API_KEY=changeme

# Production example (uncomment and set to real values):
# VITE_API_URL=https://api.yourapp.com
# VITE_API_KEY=your-production-api-key
